<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Message Details</title>
</head>

<body>
    <header>
        <a href="/" id="backBtn">Back</a>
    </header>
    <main>
        <div class="msg-head">
            <h1>
                <%= message.user %>
            </h1>
            <p>
                <%= message.added.toLocaleDateString("en-US", { 
                    month: "long" , 
                    day: "numeric" , 
                    year: "numeric" ,
                    hour: "2-digit" , 
                    minute: "2-digit" }) %>
            </p>
        </div>
        <p id="msg-text">
            <%= message.text%>
        </p>
    </main>

</body>

</html>